{
  "expo": {
    "name": "Hungr",
    "slug": "hungr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9F7F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hungr.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Hungr uses your location to find restaurants near you."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F9F7F2"
      },
      "package": "com.hungr.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Hungr uses your location to find restaurants near you."
        }
      ],
      "expo-font"
    ],
    "scheme": "hungr",
    "extra": {
      "eas": {
        "projectId": "573d3a04-dae7-4bce-bf04-a03ad239aed3"
      },
      "router": {}
    },
    "owner": "dtjk",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/573d3a04-dae7-4bce-bf04-a03ad239aed3"
    }
  }
}
